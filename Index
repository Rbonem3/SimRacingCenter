<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Colorado Springs Sim Racing Center</title>

<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@500;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">

<style>
body {
    margin: 0;
    background: #0a0a0a;
    color: white;
    font-family: Inter, sans-serif;
}

.hero {
    position: relative;
    height: 100vh;
    overflow: hidden;
}

.hero video {
    position: absolute;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.35;
}

.hero::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.55);
}

.hero-content {
    position: relative;
    z-index: 2;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    padding: 20px;
}

h1 {
    font-family: Orbitron, sans-serif;
    font-size: 3.5rem;
    max-width: 900px;
    margin: 0;
}

p {
    max-width: 700px;
    color: #ccc;
    font-size: 1.1rem;
}

.btn {
    margin-top: 20px;
    background: #e10600;
    color: white;
    text-decoration: none;
    padding: 15px 35px;
    border-radius: 8px;
    font-weight: 500;
}

.section {
    max-width: 1100px;
    margin: auto;
    padding: 80px 20px;
}

.cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
}

.card {
    background: #151515;
    padding: 25px;
    border-radius: 12px;
}

form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 500px;
}

input, select, textarea {
    background: #1c1c1c;
    border: none;
    color: white;
    padding: 12px;
    border-radius: 8px;
}

button {
    background: #e10600;
    border: none;
    color: white;
    padding: 14px;
    border-radius: 8px;
    cursor: pointer;
}
</style>
</head>

<body>

<!-- HERO -->
<section class="hero">

    <!-- Replace this with your downloaded Pexels video -->
    <video autoplay muted loop playsinline>
        <source src="hero-racing.mp4" type="video/mp4">
    </video>

    <div class="hero-content">

        <h1>Colorado Springs Sim Racing Center</h1>

        <p>
            Professional simulators. Competitive endurance racing.
            A family-friendly racing community built around Le Mans Ultimate.
        </p>

        <a href="#signup" class="btn">Join the Launch List</a>

    </div>
</section>

<!-- FEATURES -->
<section class="section">

    <div class="cards">

        <div class="card">
            <h2>Professional Simulators</h2>
            <p>High-end direct drive racing systems built for realism and endurance racing competition.</p>
        </div>

        <div class="card">
            <h2>Organized Competition</h2>
            <p>Weekly leagues, tournaments, endurance events, and structured racing formats.</p>
        </div>

        <div class="card">
            <h2>Family Friendly + Coaching</h2>
            <p>
                No experience needed. We offer beginner instruction, race coaching,
                and a welcoming environment for all skill levels.
            </p>
        </div>

    </div>
</section>

<!-- VISION -->
<section class="section">
    <h2>Our Vision</h2>
    <p style="color:#bbb;">
        We’re building a dedicated sim racing center in Colorado Springs focused on Le Mans Ultimate,
        endurance racing, and structured competitive leagues. Our goal is to create a real motorsport-style
        environment accessible to everyone.
    </p>
</section>

<!-- SIGNUP -->
<section id="signup" class="section">

    <h2>Be First on the Grid</h2>

    <form id="leadForm">

        <input name="name" placeholder="Name" required>
        <input name="email" placeholder="Email" required>

        <select name="experience">
            <option>New</option>
            <option>Intermediate</option>
            <option>Advanced</option>
        </select>

        <textarea name="interest" placeholder="What are you interested in?"></textarea>

        <input name="price" placeholder="What would you expect to pay?">

        <button type="submit">Join Launch List</button>

    </form>

</section>

</body>
</html>
